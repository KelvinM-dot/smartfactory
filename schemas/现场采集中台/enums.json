{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jqhc/product-b/enums",
  "title": "现场采集中台 · 枚举定义",
  "$defs": {
    "SurveyTaskStatus": {
      "type": "string",
      "enum": ["draft", "in_progress", "completed", "archived"]
    },
    "ShiftType": {
      "type": "string",
      "enum": ["day", "night", "middle"]
    },
    "ProductTemplate": {
      "type": "string",
      "enum": ["flux_core_wire", "welding_rod", "solid_wire"]
    },
    "ProcessStepId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "工序 ID，由 SurveyDomainConfig.process_steps 配置，可扩展"
    },
    "InputType": {
      "type": "string",
      "enum": [
        "text",
        "number",
        "boolean",
        "enum",
        "yes_no",
        "yes_no_unknown",
        "field_value",
        "multi_enum",
        "duration_min",
        "datetime",
        "composite",
        "key_question",
        "photo_ref",
        "barcode"
      ]
    },
    "Collectability": {
      "type": "string",
      "enum": [
        "plc_available",
        "hmi_display_only",
        "pressure_gauge_only",
        "manual_record",
        "needs_sensor",
        "not_available",
        "barcode_scannable",
        "ocr_possible"
      ]
    },
    "ValuePriority": {
      "type": "string",
      "enum": ["red", "yellow", "green"]
    },
    "KpiTag": {
      "type": "string",
      "enum": [
        "quality",
        "first_pass_yield",
        "rm",
        "kv2",
        "corrosion_i_value",
        "delivery_cycle",
        "oee",
        "traceability",
        "inventory_visibility",
        "energy",
        "knowledge_capture"
      ]
    },
    "SampleDataSource": {
      "type": "string",
      "enum": [
        "hmi_manual",
        "pressure_gauge",
        "paper_record",
        "operator_interview",
        "photo_ocr",
        "barcode_scan",
        "instrument_reading"
      ]
    },
    "PowderLeakLevel": {
      "type": "string",
      "enum": ["none", "slight", "severe"]
    },
    "FillRateMethod": {
      "type": "string",
      "enum": ["weighing_offline", "weighing_online", "xrf", "experience", "none"]
    },
    "CoatingThicknessMethod": {
      "type": "string",
      "enum": ["micrometer", "xrf_offline", "xrf_online", "none"]
    },
    "AgvCallMethod": {
      "type": "string",
      "enum": ["button", "system", "phone", "manual"]
    },
    "StockRecordMethod": {
      "type": "string",
      "enum": ["barcode_scan", "handwritten_ledger", "system_entry", "none"]
    },
    "WeightDeviation": {
      "type": "string",
      "enum": ["consistent", "has_deviation"]
    },
    "YesNo": {
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "ImpactLevel": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "ImplementationDifficulty": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "RecommendedCollection": {
      "type": "string",
      "enum": [
        "plc_read",
        "add_sensor",
        "barcode_scan",
        "manual_entry",
        "online_weighing",
        "xrf_online",
        "ocr"
      ]
    },
    "AttachmentType": {
      "type": "string",
      "enum": [
        "material_label",
        "hmi_screen",
        "recipe_sheet",
        "defect_sample",
        "equipment_overview",
        "paper_form",
        "other"
      ]
    },
    "InterviewCategory": {
      "type": "string",
      "enum": ["strategy", "operations", "quality_cost", "risk_compliance", "priority_ranking"]
    },
    "ExportFormat": {
      "type": "string",
      "enum": ["json", "xlsx", "pdf", "csv"]
    },
    "UserRole": {
      "type": "string",
      "enum": ["admin", "surveyor", "project_manager", "reviewer", "viewer"]
    }
  }
}
