{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jqhc/product-b/entities",
  "title": "现场采集中台 · 核心实体",
  "$defs": {
    "SurveyTask": {
      "type": "object",
      "required": ["task_id", "survey_date", "product_template", "status"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^SUR-[0-9]{8}-[0-9]{3}$", "examples": ["SUR-20260605-001"] },
        "survey_date": { "type": "string", "format": "date" },
        "product_line_id": { "type": "string", "examples": ["FCW-LINE-07"] },
        "product_template": { "$ref": "enums.json#/$defs/ProductTemplate" },
        "config_id": { "type": "string", "description": "引用的 SurveyDomainConfig.config_id" },
        "template_id": { "type": "string", "description": "引用的 SurveyTemplate.template_id" },
        "planned_grade": { "type": "string", "examples": ["HY-830MPa"] },
        "actual_batch": { "type": "string", "examples": ["FCW-20260605-B2"] },
        "shift": { "$ref": "enums.json#/$defs/ShiftType" },
        "surveyor": { "type": "string" },
        "status": { "$ref": "enums.json#/$defs/SurveyTaskStatus" },
        "site_authorization": {
          "type": "object",
          "properties": {
            "photo_allowed": { "type": "boolean" },
            "audio_allowed": { "type": "boolean" },
            "authorized_by": { "type": "string" },
            "authorized_at": { "type": "string", "format": "date-time" }
          }
        },
        "pre_shift_questions": {
          "type": "object",
          "properties": {
            "planned_grade_confirmed": { "type": "string" },
            "current_batch": { "type": "string" },
            "recent_quality_stop": { "$ref": "enums.json#/$defs/YesNo" },
            "recent_quality_stop_detail": { "type": "string" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "FieldValue": {
      "type": "object",
      "required": ["value"],
      "properties": {
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        },
        "source": { "$ref": "enums.json#/$defs/SampleDataSource" },
        "collectability": { "$ref": "enums.json#/$defs/Collectability" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      }
    },
    "PhotoAttachment": {
      "type": "object",
      "required": ["photo_id", "attachment_type", "captured_at"],
      "properties": {
        "photo_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "attachment_type": { "$ref": "enums.json#/$defs/AttachmentType" },
        "file_uri": { "type": "string" },
        "thumbnail_uri": { "type": "string" },
        "captured_at": { "type": "string", "format": "date-time" },
        "caption": { "type": "string" },
        "ocr_text": { "type": "string" },
        "barcode_value": { "type": "string" }
      }
    },
    "VoiceNote": {
      "type": "object",
      "required": ["voice_id", "task_id", "recorded_at"],
      "properties": {
        "voice_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "file_uri": { "type": "string" },
        "duration_sec": { "type": "number" },
        "transcript": { "type": "string" },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    },
    "SampleDataRecord": {
      "type": "object",
      "required": ["sample_id", "task_id", "process_step_id", "field_id", "value", "source"],
      "properties": {
        "sample_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "field_id": { "type": "string" },
        "field_name": { "type": "string" },
        "value": {
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        },
        "unit": { "type": "string" },
        "source": { "$ref": "enums.json#/$defs/SampleDataSource" },
        "sampled_at": { "type": "string", "format": "date-time" },
        "equipment_ref": { "type": "string" },
        "remark": { "type": "string" }
      }
    },
    "HighValuePoint": {
      "type": "object",
      "required": ["point_id", "task_id", "process_step_id", "data_point_name", "priority"],
      "properties": {
        "point_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "data_point_name": { "type": "string" },
        "data_point_id_suggestion": { "type": "string", "description": "建议的标准化英文 ID" },
        "priority": { "$ref": "enums.json#/$defs/ValuePriority" },
        "business_impact": { "type": "string" },
        "kpi_tags": {
          "type": "array",
          "items": { "$ref": "enums.json#/$defs/KpiTag" }
        },
        "collectability": { "$ref": "enums.json#/$defs/Collectability" },
        "recommended_method": { "$ref": "enums.json#/$defs/RecommendedCollection" },
        "impact_level": { "$ref": "enums.json#/$defs/ImpactLevel" },
        "implementation_difficulty": { "$ref": "enums.json#/$defs/ImplementationDifficulty" },
        "evidence_photo_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "OpenQuestion": {
      "type": "object",
      "required": ["question_id", "task_id", "question_text"],
      "properties": {
        "question_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "question_text": { "type": "string" },
        "asked_to": { "type": "string" },
        "answer": { "type": "string" },
        "verified": { "type": "boolean", "default": false },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "DailySummary": {
      "type": "object",
      "required": ["summary_id", "task_id", "summary_date"],
      "properties": {
        "summary_id": { "type": "string" },
        "task_id": { "type": "string" },
        "summary_date": { "type": "string", "format": "date" },
        "high_value_points": {
          "type": "array",
          "items": { "type": "string", "description": "high_value_point.point_id" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pain_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "traceability_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manual_record_pain_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surveyor_notes": { "type": "string" }
      }
    },
    "PriorityMatrixItem": {
      "type": "object",
      "required": ["item_id", "data_point_name", "impact_level", "implementation_difficulty"],
      "properties": {
        "item_id": { "type": "string" },
        "task_id": { "type": "string" },
        "process_step_id": { "$ref": "enums.json#/$defs/ProcessStepId" },
        "data_point_name": { "type": "string" },
        "impact_level": { "$ref": "enums.json#/$defs/ImpactLevel" },
        "implementation_difficulty": { "$ref": "enums.json#/$defs/ImplementationDifficulty" },
        "quadrant": {
          "type": "string",
          "enum": ["quick_win", "strategic", "fill_in", "defer"]
        },
        "recommended_method": { "$ref": "enums.json#/$defs/RecommendedCollection" },
        "estimated_cost_cny": { "type": "number" },
        "kpi_tags": {
          "type": "array",
          "items": { "$ref": "enums.json#/$defs/KpiTag" }
        }
      }
    },
    "User": {
      "type": "object",
      "required": ["user_id", "display_name", "roles"],
      "properties": {
        "user_id": { "type": "string" },
        "display_name": { "type": "string" },
        "roles": {
          "type": "array",
          "items": { "$ref": "enums.json#/$defs/UserRole" }
        },
        "enabled": { "type": "boolean" }
      }
    }
  }
}
