{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jqhc/product-b/observation-record",
  "title": "现场采集中台 · 通用观察记录",
  "description": "所有工序观察均通过 field_id + field_values 表达，字段定义由 SurveyDomainConfig 配置决定",
  "$defs": {
    "ObservationRecordBase": {
      "type": "object",
      "required": ["observation_id", "task_id", "config_id", "observed_at"],
      "properties": {
        "observation_id": { "type": "string" },
        "task_id": { "type": "string" },
        "config_id": { "type": "string" },
        "template_id": { "type": "string" },
        "record_scope": {
          "type": "string",
          "enum": ["process_step", "cross_process", "global_info"]
        },
        "process_step_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "record_scope=process_step 时必填"
        },
        "observed_at": { "type": "string", "format": "date-time" },
        "observer": { "type": "string" },
        "notes": { "type": "string" },
        "photo_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ProcessStepObservation": {
      "allOf": [
        { "$ref": "#/$defs/ObservationRecordBase" },
        {
          "type": "object",
          "required": ["record_scope", "process_step_id", "field_values"],
          "properties": {
            "record_scope": { "const": "process_step" },
            "field_values": {
              "type": "object",
              "description": "observation_field_id → FieldValue 或原始值",
              "additionalProperties": {
                "oneOf": [
                  { "$ref": "entities.json#/$defs/FieldValue" },
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "boolean" },
                  { "type": "object" }
                ]
              }
            },
            "collectability": {
              "type": "object",
              "additionalProperties": { "$ref": "enums.json#/$defs/Collectability" }
            },
            "field_annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "value_priority": { "$ref": "enums.json#/$defs/ValuePriority" },
                  "kpi_tags": {
                    "type": "array",
                    "items": { "$ref": "enums.json#/$defs/KpiTag" }
                  },
                  "recommended_collection": { "$ref": "enums.json#/$defs/RecommendedCollection" },
                  "sensor_needed": { "type": "string" }
                }
              }
            },
            "key_question_answers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["question_id", "answer"],
                "properties": {
                  "question_id": { "type": "string" },
                  "question_text": { "type": "string" },
                  "answer": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "CrossProcessObservation": {
      "allOf": [
        { "$ref": "#/$defs/ObservationRecordBase" },
        {
          "type": "object",
          "required": ["record_scope", "field_values"],
          "properties": {
            "record_scope": { "const": "cross_process" },
            "field_values": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "GlobalInfoObservation": {
      "allOf": [
        { "$ref": "#/$defs/ObservationRecordBase" },
        {
          "type": "object",
          "required": ["record_scope", "field_values"],
          "properties": {
            "record_scope": { "const": "global_info" },
            "field_values": {
              "type": "object",
              "properties": {
                "survey_date": { "type": "string", "format": "date" },
                "product_line_id": { "type": "string" },
                "planned_grade": { "type": "string" },
                "actual_batch": { "type": "string" },
                "shift": { "$ref": "enums.json#/$defs/ShiftType" },
                "surveyor": { "type": "string" },
                "planned_grade_confirmed": { "type": "string" },
                "current_batch_confirmed": { "type": "string" },
                "recent_quality_stop": { "$ref": "enums.json#/$defs/YesNo" },
                "recent_quality_stop_detail": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        }
      ]
    }
  }
}
